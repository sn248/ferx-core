# IOV + [scaling] occasion-less NONMEM anchor (#723 review).
# 1-cpt IV bolus, IOV on V, obs_scale = 1000. Mirrors nonmem_anchor/iov_scaling_anchor.ctl
# (same theta/omega/kappa/sigma; obs at t=0 after an EVID=4 reset+bolus so IPRED = AMT/V).
# Read WITHOUT an iov_column, the subjects carry no occasions, so kappa collapses to 0 and
# IPRED = (AMT/V)/obs_scale — the occasion-less path whose scaling this fixture pins.
[parameters]
  theta TVCL(1.0, 0.001, 100.0)
  theta TVV(10.0, 0.1, 1000.0)
  omega ETA_CL ~ 0.09
  omega ETA_V  ~ 0.04
  kappa KAPPA_V ~ 0.04
  sigma PROP ~ 0.05 (sd)

[scaling]
  obs_scale = 1000

[individual_parameters]
  CL = TVCL * exp(ETA_CL)
  V  = TVV  * exp(ETA_V + KAPPA_V)

[structural_model]
  pk one_cpt_iv(cl=CL, v=V)

[error_model]
  DV ~ proportional(PROP)

[fit_options]
  iov_column = OCC
