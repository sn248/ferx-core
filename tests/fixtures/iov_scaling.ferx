# IOV model WITH a divisive [scaling] block (#723 review regression fixture).
# 1-cpt IV bolus, IOV on V, obs at t=0 per occasion so raw IPRED = AMT/V; obs_scale
# divides every prediction by 1000. Used to check that simulate() applies [scaling]
# even when the data carries no occasion labels (empty occasion groups).
[parameters]
  theta TVCL(1.0, 0.001, 100.0)
  theta TVV(10.0, 0.1, 1000.0)
  omega ETA_CL ~ 0.09
  omega ETA_V  ~ 0.04
  kappa KAPPA_V ~ 0.000001
  sigma PROP ~ 0.05 (sd)

[scaling]
  obs_scale = 1000

[individual_parameters]
  CL = TVCL * exp(ETA_CL)
  V  = TVV  * exp(ETA_V + KAPPA_V)

[structural_model]
  pk one_cpt_iv(cl=CL, v=V)

[error_model]
  DV ~ proportional(PROP)

[fit_options]
  iov_column = OCC
