$PROBLEM 3-cpt oral compartment-amount reference (ferx-core issue #205)
$DATA oral3.csv IGNORE=@
$INPUT ID TIME DV AMT CMT EVID MDV
$SUBROUTINES ADVAN12 TRANS4
$PK
  CL = THETA(1)
  V2 = THETA(2)
  Q3 = THETA(3)
  V3 = THETA(4)
  Q4 = THETA(5)
  V4 = THETA(6)
  KA = THETA(7)
  S2 = V2
$ERROR
  A1 = A(1)
  A2 = A(2)
  A3 = A(3)
  A4 = A(4)
  IPRED = F
  Y = IPRED + EPS(1)
$THETA 5.0 FIX  10.0 FIX  2.0 FIX  20.0 FIX  1.5 FIX  30.0 FIX  1.0 FIX
$OMEGA 0 FIX
$SIGMA 1 FIX
$ESTIMATION MAXEVAL=0 METHOD=0 NOABORT
$TABLE ID TIME A1 A2 A3 A4 IPRED NOPRINT NOAPPEND ONEHEADER FORMAT=,1PE20.10 FILE=oral3.tab
